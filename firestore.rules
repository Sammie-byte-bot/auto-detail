rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /services/{docId} { allow read: if true; allow write: if request.auth!=null; }
    match /appointments/{docId} { allow read: if true; allow write: if request.auth!=null; }
    match /{document=**} { allow read: if true; allow write: if false; }
  }
}
